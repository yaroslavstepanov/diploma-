@startuml Field Generator - Контейнеры (C4 Level 2)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Контейнерная диаграмма Field Generator

Person(dev, "Разработчик", "Пользователь системы")

System_Boundary(field_gen, "Field Generator") {
    Container(web, "Web UI", "HTML, CSS, JavaScript", "Интерфейс настройки полей,\nгенераторов и подключения к БД")
    Container(api, "Backend API", "Python, FastAPI", "REST API, трёхслойная архитектура")
}

ContainerDb(clickhouse, "ClickHouse", "ClickHouse Server", "Хранилище сгенерированных данных")
ContainerDb(postgres, "PostgreSQL", "PostgreSQL", "Хранилище (опционально)")

Rel(dev, web, "Работает с", "HTTPS")
Rel(web, api, "Вызывает", "REST API, JSON")
Rel(api, clickhouse, "INSERT, DDL", "HTTP 8123, Native 9000")
Rel(api, postgres, "INSERT, DDL", "TCP 5432")

@enduml
